{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generic Coding Change Plan v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "title",
    "nodes",
    "edges"
  ],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 36,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "detail_row",
          "detail_col",
          "provenance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,39}$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "overview_row": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 3
          },
          "detail_row": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "detail_col": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "zone": {
            "type": "string",
            "maxLength": 40
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1,
            "properties": {
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "requirement": {
                "type": "string",
                "minLength": 1
              },
              "assumption": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "maxItems": 72,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "to",
          "provenance"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "maxLength": 50
          },
          "route": {
            "enum": [
              "orthogonal",
              "straight"
            ]
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1,
            "properties": {
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "requirement": {
                "type": "string",
                "minLength": 1
              },
              "assumption": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
