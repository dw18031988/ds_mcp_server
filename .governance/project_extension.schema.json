{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generic Coding Project Extension Metadata v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "extension_id",
    "version",
    "authoritative",
    "extends_profile",
    "core_policy",
    "core_sha256",
    "mode"
  ],
  "properties": {
    "extension_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,80}$"
    },
    "version": {
      "const": "1.0"
    },
    "authoritative": {
      "const": false
    },
    "extends_profile": {
      "type": "string",
      "minLength": 1
    },
    "core_policy": {
      "const": "CODING-PROJECT-GOVERNANCE@1.0"
    },
    "core_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mode": {
      "const": "tighten_only"
    },
    "source_note": {
      "type": "string"
    }
  }
}
